   "source": [
    "def summarizer(url):\n",
    "    content=fetch_website_contents(url)\n",
    "    response=openai.chat.completions.create(\n",
    "        model=\"gpt-4.1-mini\",\n",
    "        messages=message_for_LLM(content)\n",
    "    )\n",
    "    return response.choices[0].message.content\n",
    "    \n",
    "\n",
    "\n"
   ]
  },
  
   ],
